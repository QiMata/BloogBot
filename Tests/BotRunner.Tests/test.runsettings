<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <TargetPlatform>x86</TargetPlatform>
    <!-- Hard stop for hangs so dotnet test does not run indefinitely.
         Suite has 43 tests; combat (5m) + corpse-run×2 (4m) + gathering×2 (5m) + fixture init (90s)
         + NPC/navigation/quest/spell tests (~10m) = ~26 min. 40 min gives headroom. -->
    <TestSessionTimeout>2400000</TestSessionTimeout>
  </RunConfiguration>
</RunSettings>
