<mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1300" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="Behavior-Tree LIFO Task Stack (IBotTask)" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="40" y="20" width="900" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="stackLabel" value="LIFO Task Stack" style="text;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="120" y="90" width="320" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="onlyTop" value="Only the TOP task ticks each frame" style="text;html=1;fontSize=13;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="100" y="120" width="360" height="24" as="geometry"/>
    </mxCell>
    <mxCell id="taskTop" value="GoToTask(target)  &#8592; top, ticking" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="120" y="160" width="320" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="taskMid" value="KillTargetTask" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="120" y="220" width="320" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="taskRoot" value="GrindActivity (root task)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="120" y="280" width="320" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="bottomLbl" value="bottom = root" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="450" y="295" width="120" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="pushEdge" value="push (child)" style="endArrow=classic;html=1;strokeColor=#d79b00;strokeWidth=2;fontStyle=1;fontColor=#d79b00;" edge="1" parent="1" source="pushSrc" target="taskTop">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="pushSrc" value="" style="ellipse;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="520" y="160" width="20" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="pushNote" value="push: parent adds a child&#10;onto the stack top" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="548" y="150" width="200" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="popEdge" value="pop (Complete / Failed)" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontStyle=1;fontColor=#b85450;exitX=1;exitY=0.25;exitDx=0;exitDy=0;" edge="1" parent="1" source="taskTop" target="popDst">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="490" y="100"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="popDst" value="" style="ellipse;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="520" y="90" width="20" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="popNote" value="pop: top task removed&#10;when it ends" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="548" y="80" width="200" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="contract" value="IBotTask contract" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=1;verticalAlign=top;align=center;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="840" y="160" width="420" height="280" as="geometry"/>
    </mxCell>
    <mxCell id="cM1" value="TickAsync(ctx, ct) &#8594; Task&#10;Drive one tick; Status (BotTaskStatus) is read separately. Only the top task is ticked." style="text;html=1;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="194" width="396" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="cM2" value="OnPushedAsync(...)&#10;Fires once when this task becomes the stack top." style="text;html=1;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="248" width="396" height="46" as="geometry"/>
    </mxCell>
    <mxCell id="cM3" value="OnPoppedAsync(..., terminal)&#10;Fires once when popped (terminal: Complete or Failed)." style="text;html=1;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="298" width="396" height="46" as="geometry"/>
    </mxCell>
    <mxCell id="cM4" value="OnChildFailedAsync(..., child, reason) &#8594; bool&#10;Absorb child failure (true = keep running) or escalate.&#10;Default = false (escalate to parent)." style="text;html=1;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="348" width="396" height="62" as="geometry"/>
    </mxCell>
    <mxCell id="contractEdge" value="implements" style="endArrow=classic;html=1;dashed=1;strokeColor=#9673a6;strokeWidth=2;fontColor=#9673a6;" edge="1" parent="1" source="taskMid" target="contract">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="statusLegend" value="BotTaskStatus" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;fontStyle=1;verticalAlign=top;align=center;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="840" y="480" width="420" height="220" as="geometry"/>
    </mxCell>
    <mxCell id="stRun" value="Running&#10;Keep ticking this top task next frame." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="514" width="396" height="48" as="geometry"/>
    </mxCell>
    <mxCell id="stComplete" value="Complete&#10;Pop the task; parent resumes ticking." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="566" width="396" height="48" as="geometry"/>
    </mxCell>
    <mxCell id="stFailed" value="Failed&#10;Pop the task; OnChildFailedAsync on parent &#8594; absorb or escalate." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="852" y="618" width="396" height="64" as="geometry"/>
    </mxCell>
    <mxCell id="goToNote" value="GoToTask is the universal child &#8212; almost every Task pushes it to reposition before acting." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="100" y="380" width="360" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="flowTitle" value="Resume flow (Complete pops unwind the stack)" style="text;html=1;fontSize=15;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="100" y="500" width="600" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="f1" value="GoToTask&#10;reposition to target" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="100" y="550" width="170" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="f2" value="KillTargetTask resumes&#10;casts on target" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="330" y="550" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="f3" value="GrindActivity&#10;picks next target" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="570" y="550" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="fe1" value="Complete &#8594; pop" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;fontColor=#3a7d34;" edge="1" parent="1" source="f1" target="f2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="fe2" value="Complete &#8594; pop" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;fontColor=#3a7d34;" edge="1" parent="1" source="f2" target="f3">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="fe3" value="loop: push GoToTask for next target" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontColor=#3b5a8c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="f3" target="f1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="660" y="660"/>
          <mxPoint x="185" y="660"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
