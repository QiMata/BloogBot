    <mxCell id="title" value="WoWStateManager — Bot State Machine &amp; Mode Handlers" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="420" y="20" width="860" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="todo" value="Note: StateManagerWorker has no explicit lifecycle enum — the states below are inferred from the launch loop (ApplyDesiredWorkerState) and snapshot readiness (IsObjectManagerValid). Mode-handler names are from StateManagerMode {Test, Automated, OnDemandActivities}." style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="60" y="80" width="560" height="80" as="geometry"/>
    </mxCell>

