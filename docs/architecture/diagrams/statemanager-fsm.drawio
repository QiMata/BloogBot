    </mxCell>
    <mxCell id="sConnecting" value="Connecting&#10;(launch / inject WoW.exe or headless client)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
