    <mxCell id="modeGroup" value="MODE HANDLERS — IStateManagerModeHandler (selected at startup by StateManagerSettings.Mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
