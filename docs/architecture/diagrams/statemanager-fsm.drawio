      <mxGeometry x="120" y="820" width="150" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="sInWorld" value="InWorld&#10;(IsObjectManagerValid == true)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
