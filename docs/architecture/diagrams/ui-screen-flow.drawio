    <mxCell id="title" value="Operator UI — Screen / View Navigation (illustrative)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="520" y="30" width="680" height="40" as="geometry"/>
