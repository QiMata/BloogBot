    <mxCell id="dashboard" value="Dashboard / Bot Roster (home)&#10;DashboardView&#10;List of bots + status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
