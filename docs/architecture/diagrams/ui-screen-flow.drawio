    <mxCell id="settings" value="Global Settings / Config&#10;ConfigEditorView&#10;Service endpoints, mode&#10;defaults, feature flags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
