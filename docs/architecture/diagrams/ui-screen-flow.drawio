    <mxCell id="note" value="Views are WPF UserControls bound via MVVM to StateManager snapshot summaries; navigation is state-gated." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1340" y="600" width="300" height="110" as="geometry"/>
