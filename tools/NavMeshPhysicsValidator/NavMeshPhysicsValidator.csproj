<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>NavMeshPhysicsValidator</RootNamespace>
    <AssemblyName>NavMeshPhysicsValidator</AssemblyName>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Reuse the existing Navigation.dll P/Invoke wrapper from Navigation.Physics.Tests.
      Same pattern as PathPhysicsProbe — share the wrapper so future exports are
      picked up automatically.
    -->
    <Compile Include="..\..\Tests\Navigation.Physics.Tests\NavigationInterop.cs" Link="Interop\NavigationInterop.cs" />
  </ItemGroup>

  <!--
    Opt into legacy corrupted-state-exception propagation. By default in .NET 5+
    an AccessViolationException raised in native code tears down the process
    even when a managed try/catch wraps the P/Invoke. The GetPolyAtCoord cull
    path on tile (40, 29) reliably triggers an AV inside Detour's
    findNearestPoly that we want to tolerate and move past, not abort over.
    See project_pfs_loop19_cull_pipeline_blocker memory.
  -->
  <ItemGroup>
    <RuntimeHostConfigurationOption Include="System.Runtime.LegacyCorruptedStateExceptionsPolicy" Value="true" />
  </ItemGroup>
</Project>
