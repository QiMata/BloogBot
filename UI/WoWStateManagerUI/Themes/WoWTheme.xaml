<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         WoW Classic HUD Theme
         Colors sampled from the 1.12 default UI: dark slate panels,
         gold filigree borders, parchment text, Horde red accents.
         ═══════════════════════════════════════════════════════════ -->

    <!-- ── Color Palette ──────────────────────────────────────── -->
    <Color x:Key="WoW.Background">#FF0D0D15</Color>
    <Color x:Key="WoW.Panel">#FF1A1A2E</Color>
    <Color x:Key="WoW.PanelLight">#FF252540</Color>
    <Color x:Key="WoW.Border">#FF4A3728</Color>
    <Color x:Key="WoW.BorderGold">#FFC9A960</Color>
    <Color x:Key="WoW.Gold">#FFFFD100</Color>
    <Color x:Key="WoW.GoldDim">#FFB8972E</Color>
    <Color x:Key="WoW.Text">#FFE8DCC8</Color>
    <Color x:Key="WoW.TextDim">#FF9B8E7E</Color>
    <Color x:Key="WoW.TextBright">#FFFFF2D6</Color>
    <Color x:Key="WoW.Red">#FF8B0000</Color>
    <Color x:Key="WoW.RedBright">#FFCC3333</Color>
    <Color x:Key="WoW.Green">#FF33AA33</Color>
    <Color x:Key="WoW.Blue">#FF3366CC</Color>
    <Color x:Key="WoW.ButtonFace">#FF2A1F14</Color>
    <Color x:Key="WoW.ButtonHover">#FF3D2E1E</Color>
    <Color x:Key="WoW.ButtonPressed">#FF1A1208</Color>
    <Color x:Key="WoW.Selection">#44FFD100</Color>
    <Color x:Key="WoW.TabActive">#FF2A1F14</Color>
    <Color x:Key="WoW.TabInactive">#FF151520</Color>
    <Color x:Key="WoW.GridHeader">#FF3A2A1A</Color>
    <Color x:Key="WoW.GridRow">#FF12121E</Color>
    <Color x:Key="WoW.GridRowAlt">#FF181828</Color>
    <Color x:Key="WoW.InputBg">#FF0A0A12</Color>
    <Color x:Key="WoW.ScrollThumb">#FF4A3728</Color>
    <Color x:Key="WoW.StatusBar">#FF0A0A0F</Color>

    <!-- ── Brushes ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WoW.BackgroundBrush" Color="{StaticResource WoW.Background}"/>
    <SolidColorBrush x:Key="WoW.PanelBrush" Color="{StaticResource WoW.Panel}"/>
    <SolidColorBrush x:Key="WoW.PanelLightBrush" Color="{StaticResource WoW.PanelLight}"/>
    <SolidColorBrush x:Key="WoW.BorderBrush" Color="{StaticResource WoW.Border}"/>
    <SolidColorBrush x:Key="WoW.BorderGoldBrush" Color="{StaticResource WoW.BorderGold}"/>
    <SolidColorBrush x:Key="WoW.GoldBrush" Color="{StaticResource WoW.Gold}"/>
    <SolidColorBrush x:Key="WoW.GoldDimBrush" Color="{StaticResource WoW.GoldDim}"/>
    <SolidColorBrush x:Key="WoW.TextBrush" Color="{StaticResource WoW.Text}"/>
    <SolidColorBrush x:Key="WoW.TextDimBrush" Color="{StaticResource WoW.TextDim}"/>
    <SolidColorBrush x:Key="WoW.TextBrightBrush" Color="{StaticResource WoW.TextBright}"/>
    <SolidColorBrush x:Key="WoW.RedBrush" Color="{StaticResource WoW.Red}"/>
    <SolidColorBrush x:Key="WoW.SelectionBrush" Color="{StaticResource WoW.Selection}"/>
    <SolidColorBrush x:Key="WoW.InputBgBrush" Color="{StaticResource WoW.InputBg}"/>

    <!-- ── Window ─────────────────────────────────────────────── -->
    <Style x:Key="WoWWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WoW.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ── Global defaults ────────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
    </Style>

    <!-- ── Buttons (WoW Classic red panel buttons) ───────────── -->
    <!-- Sampled from UI-Panel-Button-Up.PNG / 128RedButton.PNG:
         Top highlight: bright crimson #9B1A1A → #AA2222
         Center body:   deep maroon   #580808 → #6B0A0A
         Bottom shadow: near-black    #1A0000 → #2A0505
         Border:        dark charcoal #2A2A2A with inner red glow #4A0808 -->
    <Style TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF9B1A1A" Offset="0.0"/>
                    <GradientStop Color="#FF7A0E0E" Offset="0.15"/>
                    <GradientStop Color="#FF580808" Offset="0.5"/>
                    <GradientStop Color="#FF3A0404" Offset="0.85"/>
                    <GradientStop Color="#FF1A0000" Offset="1.0"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource WoW.GoldBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- Outer border: dark charcoal frame -->
                    <Border x:Name="outerBorder" BorderBrush="#FF2A2A2A" BorderThickness="1" CornerRadius="1">
                        <!-- Inner border: subtle red/gold edge -->
                        <Border x:Name="innerBorder" BorderBrush="#FF4A0808" BorderThickness="1"
                                Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover: brighter red, gold outer glow -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="innerBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFBB2828" Offset="0.0"/>
                                        <GradientStop Color="#FF9A1414" Offset="0.15"/>
                                        <GradientStop Color="#FF6E0A0A" Offset="0.5"/>
                                        <GradientStop Color="#FF4A0606" Offset="0.85"/>
                                        <GradientStop Color="#FF2A0202" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF8B6914"/>
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#FF6B1010"/>
                        </Trigger>
                        <!-- Pressed: darker, flattened gradient -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="innerBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF3A0404" Offset="0.0"/>
                                        <GradientStop Color="#FF4A0808" Offset="0.3"/>
                                        <GradientStop Color="#FF580808" Offset="0.7"/>
                                        <GradientStop Color="#FF1A0000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF1A1A1A"/>
                        </Trigger>
                        <!-- Disabled: desaturated, dimmed -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource WoW.TextDimBrush}"/>
                            <Setter TargetName="innerBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF3A2020" Offset="0.0"/>
                                        <GradientStop Color="#FF2A1515" Offset="0.5"/>
                                        <GradientStop Color="#FF1A0A0A" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF1A1A1A"/>
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#FF2A1010"/>
                            <Setter TargetName="outerBorder" Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource WoW.InputBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{StaticResource WoW.GoldBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource WoW.SelectionBrush}"/>
        <Setter Property="Padding" Value="3,2"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderGoldBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ComboBox (WoW Classic dropdown) ─────────────────────
         Toggle button styled like the red panel buttons; dropdown
         popup uses dark slate with gold highlight on hover/select.
         ──────────────────────────────────────────────────────────── -->

    <!-- Toggle button inside the ComboBox (the entire clickable area) -->
    <ControlTemplate x:Key="WoW.ComboBoxToggleButton" TargetType="ToggleButton">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <!-- Main background area -->
            <Border x:Name="outerBorder" Grid.ColumnSpan="2"
                    BorderBrush="#FF2A2A2A" BorderThickness="1" CornerRadius="1">
                <Border x:Name="innerBorder" BorderBrush="#FF4A0808" BorderThickness="1"
                        CornerRadius="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF9B1A1A" Offset="0.0"/>
                            <GradientStop Color="#FF7A0E0E" Offset="0.15"/>
                            <GradientStop Color="#FF580808" Offset="0.5"/>
                            <GradientStop Color="#FF3A0404" Offset="0.85"/>
                            <GradientStop Color="#FF1A0000" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>
            <!-- Arrow glyph -->
            <Path x:Name="arrow" Grid.Column="1"
                  Data="M 0 0 L 4 4 L 8 0 Z"
                  Fill="{StaticResource WoW.GoldBrush}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="innerBorder" Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFBB2828" Offset="0.0"/>
                            <GradientStop Color="#FF9A1414" Offset="0.15"/>
                            <GradientStop Color="#FF6E0A0A" Offset="0.5"/>
                            <GradientStop Color="#FF4A0606" Offset="0.85"/>
                            <GradientStop Color="#FF2A0202" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF8B6914"/>
                <Setter TargetName="innerBorder" Property="BorderBrush" Value="#FF6B1010"/>
                <Setter TargetName="arrow" Property="Fill" Value="{StaticResource WoW.TextBrightBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="innerBorder" Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF3A0404" Offset="0.0"/>
                            <GradientStop Color="#FF4A0808" Offset="0.3"/>
                            <GradientStop Color="#FF580808" Offset="0.7"/>
                            <GradientStop Color="#FF1A0000" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF8B6914"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="innerBorder" Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF3A2020" Offset="0.0"/>
                            <GradientStop Color="#FF2A1515" Offset="0.5"/>
                            <GradientStop Color="#FF1A0A0A" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF1A1A1A"/>
                <Setter TargetName="arrow" Property="Fill" Value="{StaticResource WoW.TextDimBrush}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Editable textbox inside ComboBox (for IsEditable=True) -->
    <ControlTemplate x:Key="WoW.ComboBoxTextBox" TargetType="TextBox">
        <Border x:Name="PART_ContentHost" Focusable="False"
                Background="Transparent"/>
    </ControlTemplate>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource WoW.InputBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WoW.GoldBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Template="{StaticResource WoW.ComboBoxToggleButton}"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <!-- Selected item display -->
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="8,4,24,4"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <!-- Editable textbox (hidden unless IsEditable) -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                 Template="{StaticResource WoW.ComboBoxTextBox}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Margin="8,4,24,4"
                                 Focusable="True"
                                 Background="Transparent"
                                 Foreground="{StaticResource WoW.GoldBrush}"
                                 CaretBrush="{StaticResource WoW.GoldBrush}"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>
                        <!-- Dropdown popup -->
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <!-- Outer border: charcoal frame matching buttons -->
                                <Border x:Name="DropDownBorder"
                                        BorderBrush="#FF8B6914" BorderThickness="1"
                                        CornerRadius="0,0,2,2">
                                    <!-- Inner border: dark panel background -->
                                    <Border BorderBrush="#FF4A0808" BorderThickness="1"
                                            Background="{StaticResource WoW.PanelBrush}">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter Property="IsTabStop" Value="False"/>
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem — dropdown list items with WoW hover/select -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="itemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="#22FFD100">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="itemBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#44FFD100" Offset="0.0"/>
                                        <GradientStop Color="#22FFD100" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource WoW.TextBrightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource WoW.SelectionBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource WoW.GoldBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TabControl ─────────────────────────────────────────── -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource WoW.BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextDimBrush}"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="tabBorder" Padding="12,6"
                            Background="{StaticResource WoW.PanelBrush}"
                            BorderBrush="{StaticResource WoW.BorderBrush}"
                            BorderThickness="1,1,1,0" CornerRadius="3,3,0,0"
                            Margin="1,0,1,-1">
                        <ContentPresenter x:Name="contentPresenter" ContentSource="Header"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="tabBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource WoW.TabActive}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="tabBorder" Property="BorderBrush" Value="{StaticResource WoW.BorderGoldBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource WoW.GoldBrush}"/>
                            <Setter TargetName="tabBorder" Property="Margin" Value="1,0,1,-1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource WoW.TextBrightBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── DataGrid ───────────────────────────────────────────── -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource WoW.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground">
            <Setter.Value><SolidColorBrush Color="{StaticResource WoW.GridRow}"/></Setter.Value>
        </Setter>
        <Setter Property="AlternatingRowBackground">
            <Setter.Value><SolidColorBrush Color="{StaticResource WoW.GridRowAlt}"/></Setter.Value>
        </Setter>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="{StaticResource WoW.GridHeader}"/></Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource WoW.GoldBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="4,2"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource WoW.SelectionBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource WoW.TextBrightBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource WoW.SelectionBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="#22FFD100"/></Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── CheckBox ───────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
    </Style>

    <!-- ── Slider ─────────────────────────────────────────────── -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource WoW.GoldBrush}"/>
    </Style>

    <!-- ── ListBox ────────────────────────────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource WoW.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="FontFamily" Value="Palatino Linotype, Book Antiqua, Georgia, serif"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource WoW.SelectionBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource WoW.TextBrightBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="#22FFD100"/></Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ScrollBar ──────────────────────────────────────────── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ── StatusBar ──────────────────────────────────────────── -->
    <Style TargetType="StatusBar">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="{StaticResource WoW.StatusBar}"/></Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource WoW.TextDimBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- ── Border (for panels) ────────────────────────────────── -->
    <Style x:Key="WoWPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WoW.PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderGoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- ── PasswordBox ────────────────────────────────────────── -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource WoW.InputBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WoW.TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WoW.BorderBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource WoW.GoldBrush}"/>
        <Setter Property="Padding" Value="3,2"/>
    </Style>

    <!-- ── UserControl default background ─────────────────────── -->
    <Style TargetType="UserControl">
        <Setter Property="Background" Value="{StaticResource WoW.BackgroundBrush}"/>
    </Style>

</ResourceDictionary>
