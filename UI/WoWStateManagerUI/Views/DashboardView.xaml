<UserControl x:Class="WoWStateManagerUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WoWStateManagerUI.ViewModels"
             xmlns:convert="clr-namespace:WoWStateManagerUI.Converters"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="500">
    <UserControl.Resources>
        <convert:GreaterThanZeroToBooleanConverter x:Key="GreaterThanZeroToBooleanConverter" />
        <convert:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: URL + Exe path -->
        <Label Grid.Column="0" Grid.Row="0" Content="State URL:" />
        <TextBox Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Margin="2"
                 Text="{Binding StateManagerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>
        <Button Grid.Column="3" Grid.Row="0" Margin="4" Content="Local" Command="{Binding LocalStateManagerLoadCommand}"
                IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>
        <Button Grid.Column="4" Grid.Row="0" Margin="4" Content="Exe..." Command="{Binding BrowseExeCommand}" ToolTip="Select StateManager executable"/>
        <Button Grid.Column="5" Grid.Row="0" Margin="4" Content="Launch" Command="{Binding LaunchStateManagerCommand}"/>
        <Button Grid.Column="6" Grid.Row="0" Margin="4" Content="Stop SM" Command="{Binding StopStateManagerCommand}"/>

        <!-- Row 1: Connect/Disconnect -->
        <Button Grid.Column="0" Grid.Row="1" Margin="4" Content="Connect" Command="{Binding StateManagerConnectCommand}"
                IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>
        <Button Grid.Column="1" Grid.Row="1" Margin="4" Content="Disconnect" Command="{Binding StateManagerDisconnectCommand}"/>
        <Label Grid.Column="3" Grid.Row="1" Grid.ColumnSpan="4" Content="{Binding StatusMessage}" Foreground="DarkSlateGray" VerticalAlignment="Center"/>

        <!-- Row 2: Character DataGrid -->
        <DataGrid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="7" Margin="0,4"
                  AutoGenerateColumns="False" CanUserSortColumns="True" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Select" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Name" Binding="{Binding AccountName}" Width="175"/>
                <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="165"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 3: Pagination -->
        <Button Grid.Column="0" Grid.Row="3" Margin="4" Content="Previous"/>
        <Button Grid.Column="1" Grid.Row="3" Margin="4" Content="Next"/>
        <Label Grid.Column="2" Grid.Row="3" HorizontalContentAlignment="Center" Content="1 / 11"/>

        <!-- Right panel: Character detail -->
        <Label Grid.Column="7" Grid.Row="0" Content="Name:" />
        <Label Grid.Column="10" Grid.Row="0" Content="Level:" />
        <Label Grid.Column="7" Grid.Row="1" Content="Race:" />
        <Label Grid.Column="10" Grid.Row="1" Content="Class:" />

        <!-- Personality sliders -->
        <Label Grid.Column="7" Grid.Row="2" Grid.ColumnSpan="2" Content="Openness:"
               IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>
        <Slider Grid.Column="9" Grid.Row="2" Grid.ColumnSpan="4" Minimum="0.0" Maximum="1.0"
                Value="{Binding OpennessValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>

        <Label Grid.Column="7" Grid.Row="3" Grid.ColumnSpan="2" Content="Conscientiousness:"
               IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>
        <Slider Grid.Column="9" Grid.Row="3" Grid.ColumnSpan="4" Minimum="0.0" Maximum="1.0"
                Value="{Binding ConscientiousnessValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>

        <Label Grid.Column="7" Grid.Row="4" Grid.ColumnSpan="2" Content="Extraversion:"
               IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>
        <Slider Grid.Column="9" Grid.Row="4" Grid.ColumnSpan="4" Minimum="0.0" Maximum="1.0"
                Value="{Binding ExtraversionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>

        <Label Grid.Column="7" Grid.Row="5" Grid.ColumnSpan="2" Content="Agreeableness:"
               IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>
        <Slider Grid.Column="9" Grid.Row="5" Grid.ColumnSpan="4" Minimum="0.0" Maximum="1.0"
                Value="{Binding AgreeablenessValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>

        <Label Grid.Column="7" Grid.Row="6" Grid.ColumnSpan="2" Content="Neuroticism:"
               IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>
        <Slider Grid.Column="9" Grid.Row="6" Grid.ColumnSpan="4" Minimum="0.0" Maximum="1.0"
                Value="{Binding NeuroticismValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" VerticalAlignment="Center"/>

        <!-- Chat/command input -->
        <TextBox Grid.Column="7" Grid.Row="8" Grid.ColumnSpan="5" FontSize="12" Text="..." Margin="4"
                 IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}"/>
        <Button Grid.Column="12" Grid.Row="8" Margin="4" Content="Send"
                IsEnabled="{Binding SelectCharacterIndex, Converter={StaticResource GreaterThanZeroToBooleanConverter}}"/>
    </Grid>
</UserControl>
