<UserControl x:Class="WoWStateManagerUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WoWStateManagerUI.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             mc:Ignorable="d" d:DesignWidth="1240" d:DesignHeight="680">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Config bar (realm/world state is shown by the status circles in the title bar) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Load Config..." Command="{Binding BrowseConfigCommand}" Padding="10,4" Margin="0,0,12,0"/>
            <TextBlock Text="Config:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="{Binding ConfigName}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="{Binding ConfigFileDisplay, StringFormat='({0})'}" VerticalAlignment="Center" Foreground="DarkSlateGray"/>
        </StackPanel>

        <!-- Row 1: Unassigned bots (only visible when there are any) -->
        <Expander Grid.Row="1" Header="Unassigned live bots (not matched to any configured activity)"
                  Margin="0,0,0,6"
                  Visibility="{Binding UnassignedSnapshots.Count, Converter={StaticResource CountToVis}}">
            <DataGrid ItemsSource="{Binding UnassignedSnapshots}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      MaxHeight="160" BorderThickness="1" BorderBrush="LightGray">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="120"/>
                    <DataGridTextColumn Header="Character" Binding="{Binding CharacterName}" Width="120"/>
                    <DataGridTextColumn Header="Lv" Binding="{Binding Level}" Width="35"/>
                    <DataGridTextColumn Header="Race" Binding="{Binding RaceDisplay}" Width="80"/>
                    <DataGridTextColumn Header="Class" Binding="{Binding ClassDisplay}" Width="80"/>
                    <DataGridTextColumn Header="Area" Binding="{Binding AreaDisplay}" Width="*"/>
                    <DataGridTextColumn Header="Action" Binding="{Binding CurrentAction}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <!-- Row 2: Two-pane layout — Activities on left, character detail on right -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Pane A: Config → Activities → Characters tree (ItemsControl + Expanders) -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Activities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DashboardActivityViewModel}">
                                <Expander IsExpanded="True" Margin="2">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Margin="0,0,12,0"/>
                                            <TextBlock Text="{Binding Summary}" Foreground="DarkSlateGray"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <DataGrid ItemsSource="{Binding Characters}"
                                              SelectedItem="{Binding DataContext.SelectedCharacter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                              BorderThickness="0" Margin="20,4,4,4"
                                              MaxHeight="240" FontSize="11">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="120"/>
                                            <DataGridTextColumn Header="Character" Binding="{Binding LiveCharacterName}" Width="120"/>
                                            <DataGridTextColumn Header="Lv" Binding="{Binding LiveLevel}" Width="35"/>
                                            <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="80"/>
                                            <DataGridTextColumn Header="Class" Binding="{Binding Class}" Width="80"/>
                                            <DataGridTextColumn Header="Area" Binding="{Binding LiveAreaDisplay}" Width="*"/>
                                            <DataGridTextColumn Header="HP" Width="80">
                                                <DataGridTextColumn.Binding>
                                                    <MultiBinding StringFormat="{}{0}/{1}">
                                                        <Binding Path="LiveHealth"/>
                                                        <Binding Path="LiveMaxHealth"/>
                                                    </MultiBinding>
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Action" Binding="{Binding LiveAction}" Width="120"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding LiveStatus}" Width="60"/>
                                        </DataGrid.Columns>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLive}" Value="False">
                                                        <Setter Property="Foreground" Value="Gray"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                    </DataGrid>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- Pane B: Selected character detail (stats / spells / travel) -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Padding="6,4" Background="#22000000" FontWeight="SemiBold">
                        <Run Text="Character Detail — "/>
                        <Run Text="{Binding SelectedCharacter.AccountName, FallbackValue='(select a row)'}"/>
                    </TextBlock>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Character" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedCharacter.LiveCharacterName}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Level" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedCharacter.LiveLevel}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Race" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedCharacter.Race}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Class" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedCharacter.Class}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Area" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedCharacter.LiveAreaDisplay}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Action" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedCharacter.LiveAction}"/>
                            </Grid>

                            <TextBlock Text="Stats" FontWeight="SemiBold" Margin="0,6,0,2"/>
                            <DataGrid ItemsSource="{Binding SelectedDetail.Stats}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      MaxHeight="200" FontSize="11">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Stat" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Margin="0,8,0,0">
                                <Run Text="Spells:" FontWeight="SemiBold"/>
                                <Run Text="{Binding SelectedDetail.SpellCount, FallbackValue=0}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Travel:" FontWeight="SemiBold"/>
                                <Run Text="{Binding SelectedDetail.Travel, FallbackValue='(none)'}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Loadout:" FontWeight="SemiBold"/>
                                <Run Text="{Binding SelectedDetail.LoadoutStatus, FallbackValue='—'}"/>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 3: Status message -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="DarkSlateGray" Margin="0,6,0,0"/>
    </Grid>
</UserControl>
