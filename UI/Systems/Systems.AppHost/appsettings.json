{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },
  "WowServer": {
    "Database": {
      "User": "app",
      "Password": "app",
      "Image": "ragedunicorn/mysql",
      "Tag": "latest"
    },
    "Server": {
      "Image": "ragedunicorn/wow-vanilla",
      "Tag": "latest"
    },
    "Ports": {
      "MySql": 3306,
      "MangosWorld": 8085,
      "MangosRealm": 3724
    },
    "Volumes": {
      "MySqlData": "wow_vanilla_mysql_data",
      "MySqlPath": "/var/lib/mysql",
      "LogData": "wow_vanilla_log_data",
      "LogPath": "/var/log/wow"
    },
    "Paths": {
      "BaseDirectory": "",
      "ConfigDir": "config",
      "DataDir": "data",
      "ServerConfigPath": "/opt/vanilla/etc",
      "ServerDataPath": "/opt/vanilla/data"
    }
  }
}
